### backend/vector_db/setup.py — singleton pattern

```python
import chromadb
from chromadb.utils import embedding_functions

_client = None
_ef = None
_collections: dict = {}

def get_chroma_client():
    global _client
    if _client is None:
        _client = chromadb.PersistentClient(path="./chroma_db")
    return _client

def get_embedding_function():
    global _ef
    if _ef is None:
        _ef = embedding_functions.SentenceTransformerEmbeddingFunction(
            model_name="all-MiniLM-L6-v2"
        )
    return _ef

def get_or_create_collection(agent_name: str):
    global _collections
    if agent_name in _collections:
        return _collections[agent_name]
    collection = get_chroma_client().get_or_create_collection(
        name=f"{agent_name}s_collection",
        embedding_function=get_embedding_function(),
        metadata={"hnsw:space": "cosine"},
    )
    _collections[agent_name] = collection
    return collection

def query_collection(agent_name, queries, n_results=3):
    col = get_or_create_collection(agent_name)
    if col.count() == 0:
        return []
    results = col.query(query_texts=queries[:2], n_results=n_results,
                        include=["documents", "distances"])
    docs, seen = [], set()
    for doc_list, dist_list in zip(results["documents"], results["distances"]):
        for doc, dist in zip(doc_list, dist_list):
            if doc not in seen and dist < 0.75:
                docs.append(doc); seen.add(doc)
    return docs
