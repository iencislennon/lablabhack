```python
class BandCoordinator:
    def detect_conflicts(self) -> list[str]:
        conflicts = []
        s = self.state
        # 1. Logistics underestimates deficit urgency
        if s.farmer and s.logistics:
            if s.farmer.deficit_pct > 30 and s.logistics.logistics_risk_score < 0.3:
                conflicts.append(f"Farmer {s.farmer.deficit_pct}% deficit vs low logistics risk")
        # 2. Price cuts during critical shortage
        if s.market and s.market.stock_level_days < 14:
            for rec in s.market.price_recommendations:
                if rec.recommended_price_usd < rec.current_price_usd:
                    conflicts.append(f"Price cut on {rec.commodity} while stock={s.market.stock_level_days}d")
        # 3. Critical energy, no reserve release
        if s.energy and s.regulator:
            if s.energy.shortage_alert == "critical" and not s.regulator.emergency_reserves_release:
                conflicts.append("Critical energy shortage without reserve release")
        # 4. Subsidies during speculation
        if s.market and s.regulator:
            if s.market.speculation_detected and s.regulator.subsidy_plan:
                conflicts.append("Subsidies proposed during active speculation")
        self.state.conflicts = conflicts
        return conflicts
